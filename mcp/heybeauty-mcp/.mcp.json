{
  "name": "HeyBeauty MCP Server",
  "description": "HeyBeauty MCP Server for Virtual TryOn",
  "author": "chatmcp",
  "repository": "https://github.com/chatmcp/heybeauty-mcp",
  "config": {
    "mcpServers": {
      "heybeauty-mcp": {
        "command": "npx",
