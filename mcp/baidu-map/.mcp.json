{
  "name": "Baidu Map",
  "description": "百度地图核心API现已全面兼容MCP协议，是国内首家兼容MCP协议的地图服务商。",
  "author": "baidu-maps",
  "repository": "https://github.com/baidu-maps/mcp",
  "config": {
    "mcpServers": {
      "baidu-map": {
        "command": "npx",
        "args": [
          "-y",
          "@baidumap/mcp-server-baidu-map"
        ],
        "env": {
          "BAIDU_MAP_API_KEY": "xxx"
        }
      }
    }
  }
}
