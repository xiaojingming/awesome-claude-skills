{
  "name": "Brave Search",
  "description": "Web and local search using Brave's Search API",
  "author": "modelcontextprotocol",
  "repository": "https://github.com/modelcontextprotocol/servers/tree/main/src/brave-search",
  "config": {
    "mcpServers": {
      "brave-search": {
        "command": "docker",
        "args": [
          "run",
          "-i",
          "--rm",
          "-e",
          "BRAVE_API_KEY",
          "mcp/brave-search"
        ],
        "env": {
          "BRAVE_API_KEY": "YOUR_API_KEY_HERE"
        }
      }
    }
  }
}
