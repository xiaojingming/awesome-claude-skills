{
  "name": "Amap Maps",
  "description": "高德地图官方 MCP Server",
  "author": "amap",
  "repository": "https://github.com/modelcontextprotocol/servers",
  "config": {
    "mcpServers": {
      "amap-maps": {
        "command": "npx",
        "args": [
          "-y",
          "@amap/amap-maps-mcp-server"
        ],
        "env": {
          "AMAP_MAPS_API_KEY": "api_key"
        }
      }
    }
  }
}
