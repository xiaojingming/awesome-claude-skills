{
  "name": "mcp-server-flomo",
  "description": "Write notes to Flomo",
  "author": "chatmcp",
  "repository": "https://github.com/chatmcp/mcp-server-flomo",
  "config": {
    "mcpServers": {
      "mcp-server-flomo": {
        "command": "npx",
        "args": [
          "-y",
          "@chatmcp/mcp-server-flomo"
        ],
        "env": {
          "FLOMO_API_URL": "https://flomoapp.com/iwh/xxx/xxx/"
        }
      }
    }
  }
}
